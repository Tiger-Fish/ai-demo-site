/* ══════════════════════════════════════
   BUILD RISK ITEMS
══════════════════════════════════════ */
let checkedOnce = false;

function buildItems() {
  ['r','y','g'].forEach(lv => {
    const container = document.getElementById(`items-${lv}`);
    container.innerHTML = '';
    const lvRisks = risks.filter(r => r.level === lv);
    lvRisks.forEach(r => {
      const div = document.createElement('div');
      div.className = `risk-item ${lv}`;
      div.id = `ri-${r.id}`;
      div.innerHTML = `
        <div class="ri-top">
          <div class="ri-badge ${lv}">${lv==='r'?'高リスク':lv==='y'?'中リスク':'低リスク'}</div>
          <div class="ri-title">${r.title}</div>
        </div>
        <div class="ri-clause">${r.clause}</div>
        <div class="ri-desc">${r.desc}</div>`;
      div.addEventListener('click', () => focusClause(r.id, div));
      container.appendChild(div);
    });
  });
}

/* ══════════════════════════════════════
   FOCUS / SCROLL
══════════════════════════════════════ */
let lastFocused = null;
function focusClause(id, itemEl) {
  // remove previous
  if (lastFocused) {
    lastFocused.classList.remove('focused');
  }
  document.querySelectorAll('.risk-item').forEach(el => el.classList.remove('active-item'));

  const span = document.querySelector(`[data-id="${id}"]`);
  if (span) {
    span.classList.add('focused');
    span.scrollIntoView({ behavior:'smooth', block:'center' });
    lastFocused = span;
    setTimeout(() => span.classList.remove('focused'), 2500);
  }
  itemEl.classList.add('active-item');
}

/* ══════════════════════════════════════
   RUN CHECK
══════════════════════════════════════ */
function runCheck() {
  if (!checkedOnce) {
    buildItems();
    checkedOnce = true;
  }

  document.body.classList.add('checked');
  document.getElementById('checkBtn').classList.add('active');
  document.getElementById('checkBtn').innerHTML = '<span>✅</span> チェック完了';
  document.getElementById('summaryBar').classList.add('show');

  const rCount = risks.filter(r=>r.level==='r').length;
  const yCount = risks.filter(r=>r.level==='y').length;
  const gCount = risks.filter(r=>r.level==='g').length;
  const total  = rCount + yCount + gCount;

  document.getElementById('cntR').textContent = rCount;
  document.getElementById('cntY').textContent = yCount;
  document.getElementById('cntG').textContent = gCount;

  document.getElementById('badge-r').textContent = rCount + '件';
  document.getElementById('badge-y').textContent = yCount + '件';
  document.getElementById('badge-g').textContent = gCount + '件';

  document.getElementById('sn-r').textContent = rCount;
  document.getElementById('sn-y').textContent = yCount;
  document.getElementById('sn-g').textContent = gCount;

  // score bars
  setTimeout(() => {
    document.getElementById('sf-r').style.width = (rCount / total * 100) + '%';
    document.getElementById('sf-y').style.width = (yCount / total * 100) + '%';
    document.getElementById('sf-g').style.width = (gCount / total * 100) + '%';
  }, 100);

  // verdict
  const vb = document.getElementById('verdictBox');
  vb.textContent = `⚠️ 高リスク条項が${rCount}件検出されました。署名前に法務部門または弁護士への確認を強く推奨します。`;
}

/* ══════════════════════════════════════
   RESET
══════════════════════════════════════ */
function resetCheck() {
  document.body.classList.remove('checked');
  document.getElementById('checkBtn').classList.remove('active');
  document.getElementById('checkBtn').innerHTML = '<span>🔍</span> リスクチェック実行';
  document.getElementById('summaryBar').classList.remove('show');
  if (lastFocused) { lastFocused.classList.remove('focused'); lastFocused = null; }
}

/* ══════════════════════════════════════
   TOGGLE SECTIONS
══════════════════════════════════════ */
function toggleSec(id) {
  document.getElementById(id).classList.toggle('collapsed');
}

/* ── Click highlight spans ── */
document.querySelectorAll('.hl').forEach(span => {
  span.addEventListener('click', () => {
    const id = span.dataset.id;
    const item = document.getElementById(`ri-${id}`);
    if (item) {
      item.scrollIntoView({ behavior:'smooth', block:'center' });
      item.classList.add('active-item');
      setTimeout(() => item.classList.remove('active-item'), 2000);
    }
  });
});
